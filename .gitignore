# Build artifacts
/build
/bin/
/cloud
/cloud.exe
/admin_api
/user_api
/worker
/scheduler
/informer
/event_worker


# Configuration files (keep structure, ignore local config)
config.yaml
configs/config.yaml

# Temporary and runtime files
/tmp/
/logs/
*.log

# Local git worktrees
.worktrees/
.claude/worktrees/

# Ignore debug output directory
.vscode/.debug/

# Ignore Go debug binaries generated by Delve
cmd/*/__debug_bin*

# MinIO 数据目录（运行时生成的对象存储数据）
/storage/data/
/storage/ticket_attachments/

# MinIO 配置中的敏感文件
/storage/config/*.key
/storage/config/*.pem
/storage/config/certs/

# Local MySQL data directory (bind mount in compose.yml)
/data/

# Docker compose runtime data
/docker-data/*
!/docker-data/.gitkeep

# Test coverage reports
*.out
coverage/

# Python
__pycache__/
*.pyc
e2e/.venv/
e2e/kubeconfig.yaml
e2e/test-results/
build/logs/

# Sensitive files
*.key
*.pem
*.crt
.env
.env.local
.DS_Store
nul

# Generated architecture diagrams
/dependency-graph.html
/package-diagram.html
