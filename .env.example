# =============================================================================
# Application
# =============================================================================
APP_NAME=Cloud
APP_ENV=development
APP_DEBUG=false
# Legacy URL (deprecated)
APP_URL=http://localhost
# User API public URL (for OpenAPI documentation)
APP_API_URL=http://localhost:8080
# Admin API public URL (for OpenAPI documentation)
APP_ADMIN_API_URL=http://localhost:8081
# Frontend application URL
APP_FRONTEND_URL=http://localhost:3000
# Platform API URL injected into cluster bootstrap ConfigMap
PLATFORM_API_URL=http://localhost:8080

# =============================================================================
# Database (MySQL/TiDB)
# =============================================================================
# App database (主平台 ent)
DB_HOST=localhost
DB_PORT=4000
DB_USER=root
DB_PASSWORD=
DB_NAME=test
DB_TIMEZONE=Asia/Shanghai
# E2E test database (optional). If unset, e2e runner uses "${DB_NAME}_e2e".
E2E_DB_NAME=test

# Module database (模块 gorm)
MODULE_DB_HOST=localhost
MODULE_DB_PORT=4000
MODULE_DB_USER=root
MODULE_DB_PASSWORD=
MODULE_DB_NAME=cloud_modules
MODULE_DB_TIMEZONE=Asia/Shanghai

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# HTTP Server
# =============================================================================
HTTP_API_ENABLED=true
HTTP_API_HOST=0.0.0.0
HTTP_API_PORT=8080

HTTP_ADMIN_API_ENABLED=true
HTTP_ADMIN_API_HOST=0.0.0.0
HTTP_ADMIN_API_PORT=8081

HTTP_COLLECT_ENABLED=true
HTTP_COLLECT_HOST=0.0.0.0
HTTP_COLLECT_PORT=9091

HTTP_CORS_ENABLED=true
HTTP_CORS_ALLOWED_ORIGINS=*
HTTP_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
HTTP_CORS_ALLOW_HEADERS=*
HTTP_CORS_ALLOW_CREDENTIALS=true
HTTP_CORS_EXPOSE_HEADERS=
HTTP_CORS_MAX_AGE=3600

# =============================================================================
# JWT
# =============================================================================
# 生成密钥: ./cloud keys generate
JWT_EXPIRES_IN=86400
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# Mail (SMTP)
# =============================================================================
# 开发环境可使用 MailHog: mailhog:1025 无需认证
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@leaflow.net
# 加密方式: ssl (隐式 TLS, 465), tls (STARTTLS, 587), none (明文, 开发环境)
MAIL_ENCRYPTION=none

# =============================================================================
# Metrics
# =============================================================================
METRICS_ENABLED=false
METRICS_PORT=9090
METRICS_HOST=0.0.0.0

# =============================================================================
# S3
# =============================================================================
S3_ENDPOINT=
S3_EXTERNAL_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=false
S3_REGION=us-east-1

# =============================================================================
# OpenSearch
# =============================================================================
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INSECURE=true

# =============================================================================
# EventBus (Kafka)
# =============================================================================
BUS_BOOTSTRAP_SERVERS=localhost:9092
BUS_GROUP_ID=
BUS_TOPIC_DEFAULT=
BUS_TOPIC_DEFAULT_PARTITIONS=
BUS_TOPIC_DEFAULT_REPLICATION_FACTOR=
BUS_TOPIC_CLUSTER=
BUS_TOPIC_CLUSTER_PARTITIONS=
BUS_TOPIC_CLUSTER_REPLICATION_FACTOR=
BUS_TOPIC_TICKET=
BUS_TOPIC_TICKET_PARTITIONS=
BUS_TOPIC_TICKET_REPLICATION_FACTOR=
BUS_TOPIC_BILLING=
BUS_TOPIC_BILLING_PARTITIONS=
BUS_TOPIC_BILLING_REPLICATION_FACTOR=
BUS_TOPIC_STRIPE=
BUS_TOPIC_STRIPE_PARTITIONS=
BUS_TOPIC_STRIPE_REPLICATION_FACTOR=

# =============================================================================
# Docker
# =============================================================================
DOCKER_PLATFORM_AUTH_ENABLED=false
DOCKER_PLATFORM_AUTH_USERNAME=
DOCKER_PLATFORM_AUTH_PASSWORD=
DOCKER_IMAGE_VALIDATION_TIMEOUT_SECONDS=30
DOCKER_IMAGE_VALIDATION_CACHE_TTL=3600
DOCKER_PROXY_ENABLED=false
DOCKER_PROXY_URL=

# =============================================================================
# Trivy (漏洞扫描)
# =============================================================================
TRIVY_SERVER_URL=http://localhost:4954
TRIVY_TIMEOUT_SECONDS=600
TRIVY_CACHE_TTL_HOURS=1

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CALCULATE_TAXES=true

# =============================================================================
# Exchange Rate API (https://www.exchangerate-api.com/)
# =============================================================================
EXCHANGE_RATE_API_ENABLED=false
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# =============================================================================
# Realtime WebSocket Gateway
# =============================================================================
REALTIME_WS_HOST=0.0.0.0
REALTIME_WS_PORT=8080
REALTIME_WS_PATH=/ws
REALTIME_WS_ALLOW_ALL_ORIGINS=true
REALTIME_WS_ALLOWED_ORIGINS=[]

# =============================================================================
# Telemetry
# =============================================================================
TRACING_ENABLED=false
TRACING_QUERY_URL=http://localhost:16686
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_TRACES_SAMPLE_RATIO=100

# =============================================================================
# Monitoring (Thanos / Prometheus)
# =============================================================================
THANOS_RECEIVE_URL=http://localhost:19291
THANOS_QUERY_URL=http://localhost:9090
THANOS_QUERY_USERNAME=
THANOS_QUERY_PASSWORD=
THANOS_QUERY_TIMEOUT=30s

# =============================================================================
# Discovery (service URLs)
# =============================================================================
DISCOVERY_ISSUER=http://localhost:8080
DISCOVERY_USER_API_BASE_URL=http://localhost:8080
DISCOVERY_ADMIN_API_BASE_URL=http://localhost:8081
DISCOVERY_USER_WEB_BASE_URL=http://localhost:3000
DISCOVERY_ADMIN_WEB_BASE_URL=http://localhost:3001
DISCOVERY_REALTIME_WS_URL=ws://localhost:8080/realtime

# =============================================================================
# Captcha
# =============================================================================
CAPTCHA_PROVIDER=none
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# =============================================================================
# WebAuthn (Passkey)
# =============================================================================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_DISPLAY_NAME=Leaflow Cloud
WEBAUTHN_RP_ORIGINS=http://localhost:3000

# =============================================================================
# Build (container image builder)
# =============================================================================
BUILD_NAMESPACE=platform-git-build
BUILD_REGISTRY=registry.leaflow.internal
BUILD_REGISTRY_SECRET=leaflow-ghcr-pat
