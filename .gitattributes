# Go projects use LF line endings
* text=auto eol=lf

# Explicitly set Go files to LF
*.go text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Shell scripts
*.sh text eol=lf

# Batch files (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown
*.md text eol=lf

# SQL
*.sql text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary

*.css diff=css
*.html diff=html
*.php diff=php

CHANGELOG.md export-ignore
README.md export-ignore
.github/workflows/browser-tests.yml export-ignore
